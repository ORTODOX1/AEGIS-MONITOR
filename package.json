{
  "name": "aegis-monitor",
  "version": "0.1.0",
  "private": true,
  "description": "Ship systems monitoring dashboard -- real-time visualization of power plant and auxiliary machinery data",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "server": "tsx server/index.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"server/**/*.ts\""
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "@react-three/fiber": "^9.0.0",
    "@react-three/drei": "^10.0.0",
    "three": "^0.170.0",
    "recharts": "^2.15.0",
    "d3": "^7.9.0",
    "zustand": "^5.0.0",
    "tailwindcss": "^4.0.0",
    "express": "^5.0.0",
    "ws": "^8.18.0",
    "pg": "^8.13.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.170.0",
    "@types/d3": "^7.4.0",
    "@types/express": "^5.0.0",
    "@types/ws": "^8.5.0",
    "@types/pg": "^8.11.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "tsx": "^4.19.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.0",
    "@tailwindcss/vite": "^4.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
